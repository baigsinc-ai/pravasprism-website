    <style>
      :root {
        --bg: #0A0A0A;
        --bg2: #111111;
        --text: #ffffff;
        --text2: rgba(255,255,255,0.6);
        --text3: rgba(255,255,255,0.35);
        --border: rgba(255,255,255,0.08);
        --nav-bg: #0A0A0A;
        --hover-bg: rgba(255,255,255,0.05);
        --blue: #5170FF;
        --blue-dark: #2340CC;
        --font: 'Plus Jakarta Sans', sans-serif;
      }
      [data-theme="light"] {
        --bg: #ffffff;
        --bg2: #f5f5f7;
        --text: #0A0A0A;
        --text2: rgba(0,0,0,0.6);
        --text3: rgba(0,0,0,0.35);
        --border: rgba(0,0,0,0.08);
        --nav-bg: #ffffff;
        --hover-bg: rgba(0,0,0,0.04);
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: var(--font); background: var(--bg); color: var(--text); transition: background 0.2s, color 0.2s; }
      h1,h2,h3,h4,h5 { font-family: 'Playfair Display', serif; }

      /* HEADER */
      #site-header { position:fixed;top:0;left:0;right:0;z-index:50;background:var(--nav-bg);border-bottom:1px solid var(--border);transition:background 0.2s; }
      .nav-inner { max-width:1280px;margin:0 auto;padding:0 24px; }
      .nav-row { display:flex;align-items:center;justify-content:space-between;height:64px; }

      /* LOGO */
      .logo-link { display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0; }
      .logo-text { font-family:'Plus Jakarta Sans',sans-serif;font-size:20px;font-weight:800;color:var(--text);letter-spacing:-0.03em; }

      /* DESKTOP NAV */
      .desktop-nav { display:none;align-items:center;gap:2px; }
      .nav-btn { background:none;border:none;cursor:pointer;padding:8px 12px;font-size:14px;font-weight:500;color:var(--text2);border-radius:6px;transition:all 0.15s;font-family:var(--font); }
      .nav-btn:hover { color:var(--text);background:var(--hover-bg); }
      .nav-group { position:relative; }
      .nav-group:hover .nav-dropdown { opacity:1;visibility:visible; }
      .nav-dropdown { position:absolute;top:100%;left:0;margin-top:4px;min-width:210px;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:6px 0;opacity:0;visibility:hidden;transition:all 0.15s;z-index:100;box-shadow:0 8px 32px rgba(0,0,0,0.3); }
      .nav-drop-item { display:block;padding:10px 16px;font-size:13px;font-weight:400;color:var(--text2);text-decoration:none;transition:all 0.15s;background:none;border:none;cursor:pointer;width:100%;text-align:left;font-family:var(--font); }
      .nav-drop-item:hover { color:var(--text);background:var(--hover-bg); }
      .nav-sub-group { position:relative; }
      .nav-sub-btn { font-weight:500; }
      .nav-sub-dropdown { display:none;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:4px 0;margin:4px 8px; }
      .nav-sub-item { padding:8px 12px;font-size:12px; }

      /* RIGHT CONTROLS */
      .nav-right { display:flex;align-items:center;gap:10px; }
      .theme-btn { background:none;border:1px solid var(--border);cursor:pointer;width:36px;height:36px;border-radius:8px;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all 0.15s; }
      .theme-btn:hover { background:var(--hover-bg); }
      .cta-btn { display:none;padding:9px 18px;background:var(--blue);color:#fff;border-radius:7px;font-size:13px;font-weight:600;text-decoration:none;transition:background 0.15s;font-family:var(--font); }
      .cta-btn:hover { background:var(--blue-dark); }
      .ham-btn { background:none;border:none;cursor:pointer;padding:8px;color:var(--text2); }

      /* MOBILE MENU */
      .mob-menu { display:none;border-top:1px solid var(--border);background:var(--nav-bg);max-height:80vh;overflow-y:auto; }
      .mob-inner { padding:16px; }
      .mob-section-btn { width:100%;background:none;border:none;cursor:pointer;padding:10px 12px;font-size:14px;font-weight:500;color:var(--text2);text-align:left;border-radius:6px;font-family:var(--font); }
      .mob-section-btn:hover { color:var(--text);background:var(--hover-bg); }
      .mob-sub { display:none;padding-left:12px;border-left:1px solid var(--border);margin:4px 0 4px 12px; }
      .mob-link { display:block;padding:8px 12px;font-size:13px;color:var(--text2);text-decoration:none;border-radius:4px; }
      .mob-link:hover { color:var(--text);background:var(--hover-bg); }
      .mob-cta { display:block;text-align:center;padding:11px;background:var(--blue);color:#fff;border-radius:7px;font-size:14px;font-weight:600;text-decoration:none;font-family:var(--font); }

      /* FOOTER */
      #site-footer { background:var(--bg);border-top:1px solid var(--border);margin-top:80px; }
      .footer-inner { max-width:1280px;margin:0 auto;padding:56px 24px; }
      .footer-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:40px; }
      .footer-tagline { color:var(--text3);font-size:13px;line-height:1.7;margin-top:12px; }
      .footer-wa { display:inline-flex;align-items:center;gap:8px;margin-top:16px;font-size:13px;color:var(--text3);text-decoration:none; }
      .footer-heading { font-family:var(--font);font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:16px;color:var(--text); }
      .footer-links { display:flex;flex-direction:column;gap:10px; }
      .footer-link { color:var(--text3);font-size:13px;text-decoration:none;transition:color 0.15s; }
      .footer-link:hover { color:var(--text); }
      .footer-contact-row { display:flex;align-items:center;gap:8px; }
      .footer-cta { display:inline-block;margin-top:20px;padding:10px 20px;background:var(--blue);color:#fff;border-radius:7px;font-size:13px;font-weight:600;text-decoration:none;font-family:var(--font); }
      .footer-bottom { margin-top:48px;padding-top:24px;border-top:1px solid var(--border);display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:12px; }
      .footer-copy { color:var(--text3);font-size:12px; }
      .footer-legal { color:var(--text3);font-size:12px;text-decoration:none; }
      .footer-legal:hover { color:var(--text); }

      /* WHATSAPP FLOAT */
      .wa-float { position:fixed;bottom:24px;right:24px;z-index:50;width:56px;height:56px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,0.3);text-decoration:none;transition:transform 0.2s; }
      .wa-float:hover { transform:scale(1.1); }

      /* RESPONSIVE */
      @media (min-width:1024px) {
        .desktop-nav { display:flex !important; }
        .cta-btn { display:inline-flex !important; }
        .ham-btn { display:none !important; }
      }
    </style>

    <script>
      function toggleTheme() {
        const html = document.documentElement;
        const isDark = html.getAttribute('data-theme') === 'dark';
        html.setAttribute('data-theme', isDark ? 'light' : 'dark');
        const icon = document.getElementById('theme-icon');
        if (icon) icon.textContent = isDark ? '☀️' : '🌙';
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
      }

      // Apply saved theme on load
      const saved = localStorage.getItem('theme');
      if (saved) {
        document.documentElement.setAttribute('data-theme', saved);
        const icon = document.getElementById('theme-icon');
        if (icon) icon.textContent = saved === 'light' ? '☀️' : '🌙';
      }

      // Hamburger
      const hamburgerBtn = document.getElementById('hamburger-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamIcon = document.getElementById('ham-icon');
      const closeIcon = document.getElementById('close-icon');
      let menuOpen = false;
      hamburgerBtn?.addEventListener('click', () => {
        menuOpen = !menuOpen;
        if (mobileMenu) mobileMenu.style.display = menuOpen ? 'block' : 'none';
        if (hamIcon) hamIcon.style.display = menuOpen ? 'none' : 'block';
        if (closeIcon) closeIcon.style.display = menuOpen ? 'block' : 'none';
      });

      function toggleMobSection(id) {
        const el = document.getElementById(id);
        if (el) el.style.display = el.style.display === 'none' || el.style.display === '' ? 'block' : 'none';
      }

      function toggleSchengen(e) {
        e.stopPropagation();
        const sub = document.getElementById('schengen-sub');
        if (sub) sub.style.display = sub.style.display === 'none' || sub.style.display === '' ? 'block' : 'none';
      }

      (window as any).toggleMobSection = toggleMobSection;
      (window as any).toggleSchengen = toggleSchengen;
      (window as any).toggleTheme = toggleTheme;
    </script>

  </body>
</html>