    if (monument) monument.style.transform = `translateY(${window.scrollY * 0.15}px)`;
  }
  window.addEventListener('scroll', updateParallax, { passive: true });

  // VERTICAL TIMELINE ACCORDION
  document.querySelectorAll('.vtl-header').forEach(header => {
    header.addEventListener('click', () => {
      const item = header.closest('.vtl-item');
      if (!item) return;
      const isOpen = item.classList.contains('vtl-open');
      document.querySelectorAll('.vtl-item').forEach(i => i.classList.remove('vtl-open'));
      if (!isOpen) item.classList.add('vtl-open');
    });
  });

  // SERVICES ACCORDION
  document.querySelectorAll('.acc-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-target');
      const body = document.getElementById(target);
      const plus = btn.querySelector('.acc-plus');
      const isOpen = btn.classList.contains('acc-open');
      document.querySelectorAll('.acc-btn').forEach(b => { b.classList.remove('acc-open'); const p = b.querySelector('.acc-plus'); if (p) p.textContent = '+'; });
      document.querySelectorAll('.acc-body').forEach(b => b.classList.remove('open'));
      if (!isOpen && body && plus) { body.classList.add('open'); btn.classList.add('acc-open'); plus.textContent = '−'; }
    });
  });

  // FAQ ACCORDION
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-target');
      const body = document.getElementById(target);
      const plus = btn.querySelector('.faq-plus');
      const isOpen = btn.classList.contains('faq-open');
      document.querySelectorAll('.faq-btn').forEach(b => { b.classList.remove('faq-open'); const p = b.querySelector('.faq-plus'); if (p) p.textContent = '+'; });
      document.querySelectorAll('.faq-body').forEach(b => b.classList.remove('open'));
      if (!isOpen && body && plus) { body.classList.add('open'); btn.classList.add('faq-open'); plus.textContent = '−'; }
    });
  });

  // FLOATING INDEX BALL
  const floatBall = document.getElementById('float-ball');
  const floatPanel = document.getElementById('float-panel');
  let panelOpen = false;
  floatBall?.addEventListener('click', (e) => {
    e.stopPropagation();
    panelOpen = !panelOpen;
    if (floatPanel) floatPanel.style.display = panelOpen ? 'flex' : 'none';
  });
  document.querySelectorAll('.float-link').forEach(link => {
    link.addEventListener('click', () => { panelOpen = false; if (floatPanel) floatPanel.style.display = 'none'; });
  });
  document.addEventListener('click', (e) => {
    const wrap = document.getElementById('float-wrap');
    if (panelOpen && wrap && !wrap.contains(e.target as Node)) { panelOpen = false; if (floatPanel) floatPanel.style.display = 'none'; }
  });

  // SMOOTH SCROLL
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', (e) => {
      const href = a.getAttribute('href');
      if (href && href.startsWith('#')) {
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - 80, behavior: 'smooth' });
      }
    });
  });
</script>