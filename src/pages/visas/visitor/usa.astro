  <!-- DOCUMENTS -->
  <section id="documents" class="vp-section">
    <div class="vp-container">
      <h2 class="vp-h2">Documents Required</h2>
      <p class="vp-lead">Standard checklist for Indian passport holders. Individual cases may vary.</p>
      <div class="docs-grid">
        <div class="docs-col">
          <div class="docs-col-head">📌 Mandatory</div>
          <ul class="docs-list">
            <li>Valid passport — 6+ months validity, 2 blank pages</li>
            <li>DS-160 confirmation page (printed)</li>
            <li>Visa fee payment receipt ($185)</li>
            <li>Interview appointment confirmation letter</li>
            <li>Passport photo — 2"×2", white background</li>
          </ul>
        </div>
        <div class="docs-col">
          <div class="docs-col-head">📎 Supporting Documents</div>
          <ul class="docs-list">
            <li>Bank statements — last 6 months</li>
            <li>Income Tax Returns — last 3 years</li>
            <li>Employment letter / business registration</li>
            <li>Property or fixed asset documents</li>
            <li>Travel itinerary (flight + hotel)</li>
            <li>Invitation letter if visiting family/friends</li>
            <li>Old passports with prior travel stamps</li>
          </ul>
        </div>
      </div>
      <div class="docs-note">
        Not sure if your documents are strong enough?
        <a href="/book?service=doc-audit-usa">Book a free document audit →</a>
      </div>
    </div>
  </section>

