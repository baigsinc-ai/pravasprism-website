              <a href="/book" class="vtl-cta">Book Now →</a>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="vtl-item">
          <div class="vtl-track">
            <div class="vtl-dot"></div>
            <div class="vtl-line"></div>
          </div>
          <div class="vtl-content">
            <div class="vtl-header">
              <div class="vtl-title-group">
                <span class="vtl-title">DS-160 Form</span>
                <span class="vtl-sub">Day 2–3</span>
